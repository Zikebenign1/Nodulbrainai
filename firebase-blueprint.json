{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email"]
    },
    "Chat": {
      "title": "Chat Session",
      "description": "Represents a chat session with a specific AI mode.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mode", "createdAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a chat session.",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "ai"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["content", "role", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Chat session document."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Message document within a chat session."
    }
  }
}
